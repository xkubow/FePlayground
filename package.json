{
  "name": "FePlayground",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node setup-mocks.js",
    "msw:setup": "node setup-mocks.js",
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "host": "vite --host --https",
    "build3": "vue-tsc -b && vite build",
    "build": "vue-tsc --noEmit && vite build",
    "build:analyze": "vue-tsc --noEmit && vite build --mode analyze && node -e \"console.log('\\n  Bundle report: dist/bundle-stats.html  (open this file — not index.html)\\n')\"",
    "buildTest": "set \"VITE_CJS_TRACE=true\" && vite build",
    "build_dev": "vue-tsc --noEmit && vite build --mode development",
    "preview": "vite preview --port 5050",
    "storybook:clean": "node -e \"require('fs').rmSync('node_modules/.cache/storybook',{ recursive: true, force: true })\"",
    "storybook": "npm run storybook:clean && storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test:storybook": "vitest --project=storybook",
    "test:storybook:coverage": "vitest --project=storybook --coverage",
    "test:unit": "vitest --environment jsdom",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:html": "cypress run --reporter mochawesome --reporter-options reportDir=cypress/reports,overwrite=false,html=true,json=true",
    "test:e2e": "start-server-and-test preview http://localhost:5050 cy:run",
    "test:e2e:mock": "start-server-and-test dev:mock http://localhost:5173 cy:run",
    "test:e2e:mock:html": "start-server-and-test dev:mock http://localhost:5173 cy:run:html",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore"
  },
  "dependencies": {
    "@json2csv/plainjs": "^7.0.6",
    "@tiptap/extension-color": "^2.12.0",
    "@tiptap/extension-link": "^2.12.0",
    "@tiptap/extension-placeholder": "^2.12.0",
    "@tiptap/extension-text-style": "^2.12.0",
    "@tiptap/extension-typography": "^2.12.0",
    "@tiptap/starter-kit": "^2.12.0",
    "@tiptap/vue-3": "^2.12.0",
    "@types/json2csv": "^5.0.7",
    "@types/vue-barcode-reader": "^0.0.3",
    "axios": "^1.12.0",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.5",
    "element-plus": "^2.13.0",
    "jsdom": "^26.1.0",
    "json2csv": "^5.0.7",
    "linkifyjs": "^4.3.2",
    "lodash": "^4.17.21",
    "object-hash": "^3.0.0",
    "pinia": "^3.0.2",
    "qs": "^6.14.1",
    "simple-keyboard": "^3.8.54",
    "simple-keyboard-layouts": "^3.4.88",
    "vue": "^3.5.13",
    "vue-axios": "^3.5.2",
    "vue-barcode-reader": "^1.0.3",
    "vue-dompurify-html": "^5.3.0",
    "vue-i18n": "^11.1.3",
    "vue-remix-icons": "^3.15.0",
    "vue-router": "^4.5.1",
    "vue3-qrcode-reader": "^0.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@rushstack/eslint-patch": "^1.11.0",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-vitest": "^10.3.3",
    "@storybook/vue3-vite": "^10.3.3",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^21.1.7",
    "@types/json2csv": "^5.0.7",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.15.17",
    "@types/object-hash": "^3.0.6",
    "@types/qs": "^6.9.18",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.1.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.7.0",
    "cypress": "^14.5.4",
    "eslint": "^9.39.3",
    "eslint-plugin-cypress": "^4.3.0",
    "eslint-plugin-vue": "^10.8.0",
    "form-data": "^4.0.4",
    "globals": "^17.4.0",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "msw": "^2.12.10",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "puppeteer": "^24.34.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.87.0",
    "start-server-and-test": "^2.0.11",
    "storybook": "^10.3.3",
    "ts-morph": "^27.0.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.56.1",
    "unplugin-auto-import": "^19.2.0",
    "unplugin-vue-components": "^28.5.0",
    "vite": "^6.3.5",
    "vitest": "^3.1.3",
    "vue-tsc": "^2.2.10"
  }
}
